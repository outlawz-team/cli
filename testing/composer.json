{
    "name": "roots/radicle",
    "type": "project",
    "license": "MIT",
    "description": "Radicle is an opinionated starting point for WordPress projects with the Roots stack",
    "homepage": "https://roots.io/radicle/",
    "authors": [
        {
            "name": "Ben Word",
            "email": "ben@benword.com",
            "homepage": "https://github.com/retlehs"
        }
    ],
    "repositories": [
        {
            "name": "advanced-custom-fields",
            "type": "composer",
            "url": "https://connect.advancedcustomfields.com"
        },
        {
            "name": "wp-packages",
            "type": "composer",
            "url": "https://repo.wp-packages.org"
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/helpers.php"
        ]
    },
    "require": {
        "php": ">=8.4",
        "blade-ui-kit/blade-heroicons": "^2.7",
        "blade-ui-kit/blade-icons": "^1.9",
        "composer/installers": "^2.2",
        "guzzlehttp/guzzle": "^7.10",
        "log1x/acorn-disable-media-pages": "^1.0",
        "log1x/laravel-webfonts": "^2.0",
        "oscarotero/env": "^2.1",
        "outlawz-team/radicle": "^1.0",
        "roots/acorn": "^5.1",
        "roots/acorn-mail": "^1.0",
        "roots/acorn-post-types": "^1.0",
        "roots/acorn-prettify": "^1.0",
        "roots/allow-svg": "^1.0",
        "roots/bedrock-autoloader": "^1.1",
        "roots/bedrock-disallow-indexing": "^2.1",
        "roots/wordpress": "6.9.4",
        "roots/wp-config": "1.0.0",
        "roots/wp-stage-switcher": "^2.4",
        "stoutlogic/acf-builder": "^1.12",
        "vlucas/phpdotenv": "^5.6",
        "wpengine/advanced-custom-fields-pro": "^6.7"
    },
    "require-dev": {
        "johnbillion/query-monitor": "^3.20",
        "laravel/pint": "^1.29",
        "pestphp/pest": "^4.4",
        "phpcompatibility/php-compatibility": "^9.3"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "composer/installers": true,
            "roots/wordpress-core-installer": true,
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "acorn": {
            "providers": [
                "App\\Providers\\ApiServiceProvider",
                "App\\Providers\\AssetsServiceProvider",
                "App\\Providers\\BlocksServiceProvider",
                "App\\Providers\\ThemeServiceProvider"
            ]
        },
        "installer-paths": {
            "public/content/mu-plugins/{$name}/": [
                "type:wordpress-muplugin"
            ],
            "public/content/plugins/{$name}/": [
                "type:wordpress-plugin"
            ],
            "public/content/themes/{$name}/": [
                "type:wordpress-theme"
            ]
        },
        "wordpress-install-dir": "public/wp"
    },
    "scripts": {
        "lint": "pint --test",
        "lint:fix": "pint",
        "test": "pest",
        "post-autoload-dump": [
            "Roots\\Acorn\\ComposerScripts::postAutoloadDump"
        ]
    }
}
